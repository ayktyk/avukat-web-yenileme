{
  "redirects": [
    {
      "source": "/admin/api/cms/:path*",
      "destination": "/api/cms/:path*",
      "permanent": false
    },
    {
      "source": "/config.yml",
      "destination": "/admin/config.yml",
      "permanent": false
    },
    {
      "source": "/admin",
      "destination": "/admin/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/blog/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/guncel-hukuk-gundemi/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/kvkk-aydinlatma",
      "destination": "/index.html"
    },
    {
      "source": "/cerez-politikasi",
      "destination": "/index.html"
    },
    {
      "source": "/hukuki-uyari",
      "destination": "/index.html"
    }
  ]
}
